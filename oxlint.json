{
	"$schema": "./node_modules/oxlint/configuration_schema.json",
	"plugins": [
		"eslint",
		"typescript",
		"unicorn",
		"oxc",
		"import",
		"promise",
		"node"
	],
	"categories": {
		"correctness": "error",
		"suspicious": "error",
		"pedantic": "error",
		"perf": "error",
		"style": "error",
		"restriction": "error",
		"nursery": "warn"
	},
	"rules": {
		"eslint/max-statements": "off",
		"eslint/sort-keys": "off",
		"import/no-named-export": "off",
		"import/no-nodejs-modules": "off",
		"import/prefer-default-export": "off",
		"unicorn/prefer-module": "off"
	},
	"env": {
		"builtin": true,
		"node": true
	},
	"globals": {},
	"ignorePatterns": ["**/*.d.ts"]
}
