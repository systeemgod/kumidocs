{
	"name": "kumidocs",
	"version": "0.0.0",
	"description": "A developer-focused wiki/docs platform with zero database — all content stored in Git.",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/Foorack/kumidocs.git"
	},
	"keywords": ["wiki", "docs", "markdown", "git", "bun", "self-hosted"],
	"publishConfig": {
		"access": "public"
	},
	"engines": {
		"bun": ">=1.1.0"
	},
	"files": ["dist"],
	"bin": {
		"kumidocs": "dist/index.js"
	},
	"type": "module",
	"scripts": {
		"build": "bun scripts/build.ts",
		"prepublishOnly": "bun run build",
		"dev": "bun --hot src/index.ts",
		"start": "NODE_ENV=production bun src/index.ts",
		"lint": "bunx prettier --check . && bunx eslint .",
		"format": "bunx prettier --write .",
		"ts": "bunx tsc --noEmit"
	},
	"dependencies": {},
	"devDependencies": {
		"bun-plugin-tailwind": "0.1.2",
		"@fluentui/react-icons": "2.0.320",
		"@noble/hashes": "2.0.1",
		"@radix-ui/react-label": "2.1.8",
		"@radix-ui/react-select": "2.2.6",
		"@radix-ui/react-slot": "1.2.4",
		"@streamdown/cjk": "1.0.2",
		"@streamdown/code": "1.1.0",
		"@streamdown/math": "1.0.2",
		"@tailwindcss/typography": "0.5.19",
		"@uiw/codemirror-extensions-langs": "4.25.8",
		"@uiw/codemirror-theme-github": "4.25.8",
		"@uiw/react-codemirror": "4.25.8",
		"class-variance-authority": "0.7.1",
		"clsx": "2.1.1",
		"cmdk": "1.1.1",
		"diff": "8.0.3",
		"gray-matter": "4.0.3",
		"html2canvas-pro": "2.0.2",
		"isomorphic-git": "1.37.3",
		"jspdf": "4.2.1",
		"lucide-react": "0.577.0",
		"minisearch": "7.2.0",
		"next-themes": "0.4.6",
		"radix-ui": "1.4.3",
		"react": "19.2.4",
		"react-diff-view": "3.3.2",
		"react-dom": "19.2.4",
		"react-router-dom": "7.13.1",
		"rehype-harden": "1.1.8",
		"sonner": "2.0.7",
		"streamdown": "2.4.0",
		"tailwind-merge": "3.5.0",
		"@eslint/js": "10.0.1",
		"@types/bun": "1.3.10",
		"@types/react": "19.2.14",
		"@types/react-dom": "19.2.3",
		"country-flag-icons": "1.6.15",
		"eslint-plugin-erasable-syntax-only": "0.4.0",
		"eslint-plugin-react": "7.37.5",
		"eslint-plugin-react-hooks": "7.0.1",
		"globals": "17.4.0",
		"prettier": "3.8.1",
		"tailwindcss": "4.2.1",
		"tw-animate-css": "1.4.0",
		"typescript-eslint": "8.57.0"
	}
}
