# KumiDocs Instance Configuration
KUMIDOCS_INSTANCE_NAME=KumiDocs
# Git backend: 'native' (system git binary, default) or 'builtin' (pure-JS isomorphic-git)
KUMIDOCS_GIT_IMPL=native

# SSO Proxy OAuth Configuration
# Supports: github, google, oidc, etc. (see oauth2-proxy docs)
SSO_PROXY_PROVIDER=github
SSO_PROXY_CLIENT_ID=your_oauth_client_id_here
SSO_PROXY_CLIENT_SECRET=your_oauth_client_secret_here
SSO_PROXY_REDIRECT_URL=http://localhost:5865/oauth2/callback
SSO_PROXY_COOKIE_DOMAIN=localhost
SSO_PROXY_COOKIE_SECURE=false
